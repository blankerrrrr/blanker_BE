{
  "manifest_version": 3,
  "name": "Blanker",
  "description": "Analyze page content and block spoiler or harmful content.",
  "version": "0.1.0",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Blanker"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://blanker-api.duckdns.org/*"
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ]
}

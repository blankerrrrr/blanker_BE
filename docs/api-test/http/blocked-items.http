@host = http://127.0.0.1:8000
@accessToken =
@blockedItemId =
@interestTargetId =

### 보관함 목록 조회
GET {{host}}/api/blocked-items?interestTargetId={{interestTargetId}}&type=SPOILER
Authorization: Bearer {{accessToken}}

### 보관함 저장
POST {{host}}/api/blocked-items
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "analysisRequestId": "analysis_test",
  "clientContentId": "node_001",
  "interestTargetId": "{{interestTargetId}}",
  "summary": "차단된 콘텐츠 요약",
  "categories": ["SPOILER"],
  "relatedTopics": ["테스트 작품"],
  "sourceUrl": "https://example.com/blocked-item",
  "selector": "article > p:nth-child(1)",
  "positionText": "본문 첫 번째 문단"
}

### 보관함 삭제
DELETE {{host}}/api/blocked-items/{{blockedItemId}}
Authorization: Bearer {{accessToken}}
